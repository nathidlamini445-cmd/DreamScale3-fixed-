# DreamScale — copy to .env.local and fill in values.
# Next.js loads: .env.local (and .env) for `npm run dev`

# Canonical public URL of this deployment (no trailing slash). Strongly recommended on
# Vercel when using a custom domain so OAuth redirects and cookies match the browser host.
# Example: https://app.dreamscale.co.za
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Required for auth, database, middleware (app will error without these)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# If Supabase has CAPTCHA/Bot Protection ON with Cloudflare Turnstile — required
# for email/password sign-up, sign-in, and forgot-password. Same provider + secret
# in Dashboard → Authentication → Bot Protection.
# Keys: https://dash.cloudflare.com/ → Turnstile (allow http://localhost:3000 in widget hosts)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Core AI (used by most /api routes, chat, DreamPulse, file processing, etc.)
# Get a key: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_TOKENS=16384
GEMINI_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# YouTube (server prefers YOUTUBE_API_KEY; client components use NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
NEXT_PUBLIC_YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Notion (Pro) — export Systems to Notion pages
# Create integration: https://www.notion.so/my-integrations
# Redirect URI must match: {NEXT_PUBLIC_SITE_URL}/api/integrations/notion/callback
# -----------------------------------------------------------------------------
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Google (Pro) — Docs, Sheets, Calendar
# Google Cloud Console → enable: Drive, Docs, Sheets, Calendar APIs
# OAuth redirect: {NEXT_PUBLIC_SITE_URL}/api/integrations/google/callback
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Slack (Pro) — send roadmap & revenue summaries to a channel
# Create app: https://api.slack.com/apps → OAuth & Permissions
# Redirect: {NEXT_PUBLIC_SITE_URL}/api/integrations/slack/callback
# Scopes: chat:write, channels:read
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Airtable (Pro) — export structured rows to your base
# Create OAuth integration: https://airtable.com/create/oauth
# Redirect: {NEXT_PUBLIC_SITE_URL}/api/integrations/airtable/callback
# -----------------------------------------------------------------------------
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Optional — only if you use these features
# -----------------------------------------------------------------------------
# OpenAI — monitor-competitor route
OPENAI_API_KEY=

# Scraping/API — analyze-competitor route (e.g. ScraperAPI or similar)
SCRAPER_API_KEY=

# Reward download links — set in production; falls back to anon key if unset
DOWNLOAD_TOKEN_SECRET=

# Transactional email — optional; workspace invites also work via "Send from your email" (mailto)
# Free tier at resend.com — 100 emails/day. Without this, invites open your Gmail/Outlook instead.
RESEND_API_KEY=
RESEND_FROM=

# -----------------------------------------------------------------------------
# Clerk (replaces Supabase Auth for sign-in). Get keys in Clerk Dashboard.
# After sign-in, users are sent to /auth/resolve (also set in Clerk Dashboard → Paths).
# Use FALLBACK_REDIRECT_URL — AFTER_SIGN_IN_URL is deprecated and logs console warnings.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/resolve
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
# Webhook signing secret — Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Supabase service role — server-only. Used by Clerk webhook to upsert user_profiles.
# Never expose to the browser.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# PayFast — subscriptions (Pay Now: receiver + passphrase for ITN)
# custom_str1 = Clerk user id (user_…) from /billing when signed in
# -----------------------------------------------------------------------------
PAYFAST_RECEIVER=
PAYFAST_PROCESS_URL=https://payment.payfast.io/eng/process
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# Pro = $19.99/mo USD; PayFast charges ZAR equivalent (override amounts only if needed)
NEXT_PUBLIC_PRO_MONTHLY_USD=19.99
NEXT_PUBLIC_ZAR_PER_USD=18.5
PAYFAST_SUBSCRIPTION_AMOUNT=
PAYFAST_RECURRING_AMOUNT=
PAYFAST_ITN_VALIDATE_URL=https://www.payfast.co.za/eng/query/validate
# PayFast REST API (subscription cancel). Set true for sandbox subscriptions.
PAYFAST_API_TESTING=
PAYFAST_API_BASE_URL=https://api.payfast.co.za
